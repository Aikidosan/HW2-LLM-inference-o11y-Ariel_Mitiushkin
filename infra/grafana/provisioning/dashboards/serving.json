    {
      "id": 9,
      "type": "row",
      "title": "Throughput",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "panels": []
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Tokens / sec (input + output)",
