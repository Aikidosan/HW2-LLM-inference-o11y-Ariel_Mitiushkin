    {
      "id": 16,
      "type": "timeseries",
      "title": "Prefix cache hit rate %",
      "description": "Cached prompt tokens reused / queried (5m). Higher = more shared-prefix reuse (schema + system prompt).",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 26
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "100 * sum(rate(vllm:prefix_cache_hits_total[5m])) / clamp_min(sum(rate(vllm:prefix_cache_queries_total[5m])), 1)",
